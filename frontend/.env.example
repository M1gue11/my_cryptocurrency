# Endpoint JSON-RPC que o frontend usa.
# Padrão (quando não definido): http://localhost:7001/rpc
#
# Para apontar para os nós da simulação (docker-compose.sim.yml):
#   node1 -> http://localhost:7101/rpc
#   node2 -> http://localhost:7102/rpc
#   node3 -> http://localhost:7103/rpc
#   node4 -> http://localhost:7104/rpc
#
# Copie este arquivo para .env.local e ajuste a URL desejada.
VITE_RPC_URL=http://localhost:7101/rpc
